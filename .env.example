# Copy this file to .env and fill sensitive values. Do NOT commit .env.
# Example values:
SECRET_KEY=replace-with-a-very-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (example)
DB_NAME=shoe_store
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3307

# Bcrypt rounds (cost factor) - must be >= 10
BCRYPT_ROUNDS=12

# Token lifetimes (days)
ACCESS_TOKEN_DAYS=7
REFRESH_TOKEN_DAYS=7

# HTTPS deployment
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
